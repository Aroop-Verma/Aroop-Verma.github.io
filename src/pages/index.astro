---
import Base from "../layouts/Base.astro";
---

<Base>
  <section class="hero">
    <h1><span class="gradient-text">Aroop Verma</span></h1>
    <p class="oneliner">biology, data, and the space between</p>
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(2rem, 12vh, 7rem);
  }

  h1 {
    margin: 0 0 0.6rem;
    animation: reveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }

  .oneliner {
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    letter-spacing: 0.06em;
    animation: reveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.35s backwards;
  }

  /* Typewriter, once the name has landed. clip-path sweeps left-to-right in
     one step per character — Monocraft is monospace, so each step is exactly
     one glyph. Only applied where the line fits on a single row: wrapped, the
     sweep would cut across both rows at once. */
  @media (min-width: 480px) {
    .oneliner {
      width: fit-content;
      animation: type 1.6s steps(36, end) 0.8s backwards;
    }
  }

  @keyframes type {
    from {
      clip-path: inset(0 100% 0 0);
    }
    to {
      clip-path: inset(0 0 0 0);
    }
  }

  /* Starting state lives in the keyframes, not the base rule: the global
     reduced-motion override drops the animation, and anything hidden here
     would stay hidden. */
  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
  }
</style>

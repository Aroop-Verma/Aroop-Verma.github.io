---
import Base from "../layouts/Base.astro";
---

<Base>
  <section class="hero">
    <h1><span class="gradient-text">Aroop Verma</span></h1>
    {/* Split so each fragment can be swept on its own. The joining space is a
        hard &nbsp; inside fragment a — the compiler strips whitespace between
        the tags, and a plain space would collapse at the line break anyway. */}
    <p class="oneliner">
      <span class="frag a">biology, data,&nbsp;</span><span class="frag b"
        >and the space between</span
      >
    </p>
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(2rem, 12vh, 7rem);
  }

  h1 {
    margin: 0 0 0.6rem;
    animation: reveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }

  .oneliner {
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    letter-spacing: 0.06em;
  }

  /* Typewriter, once the name has landed. clip-path sweeps left-to-right in
     one step per character — Monocraft is monospace, so each step is exactly
     one glyph, and the step count of each fragment must match its own
     character count.

     inline-block so the box hugs its text: the sweep is a percentage of the
     border box, and a full-width block would make it lag behind the glyphs.
     Sweeping each fragment separately is also what lets this run on phones —
     one sweep across a wrapped line would cut through both rows at once. */
  .frag {
    display: inline-block;
  }

  .frag.a {
    /* 15 chars incl. the trailing nbsp: 15/36 of the 1.6s budget */
    animation: type 0.67s steps(15, end) 0.8s backwards;
  }

  .frag.b {
    /* 21 chars, starting after fragment a and its trailing space */
    animation: type 0.93s steps(21, end) 1.47s backwards;
  }

  /* Below 480px the line can't fit on one row. Forcing the break here puts it
     where the fragments already split, so each row is swept by exactly one
     animation instead of wrapping mid-fragment. */
  @media (max-width: 479px) {
    .frag {
      display: block;
      width: fit-content;
    }
  }

  @keyframes type {
    from {
      clip-path: inset(0 100% 0 0);
    }
    to {
      clip-path: inset(0 0 0 0);
    }
  }

  /* Starting state lives in the keyframes, not the base rule: the global
     reduced-motion override drops the animation, and anything hidden here
     would stay hidden. */
  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
  }
</style>

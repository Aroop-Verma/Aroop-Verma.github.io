---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<Base title="Blog — Aroop Verma" description="Notes and writing.">
  <h1><span class="gradient-text">blog</span></h1>
  <hr class="rule" />

  {posts.length === 0 && <p class="muted">No posts yet.</p>}

  <div class="post-grid">
    {
      posts.map((post) => (
        <a class="card post" href={`/blog/${post.id}`}>
          <h2 class="title">{post.data.title}</h2>
          {post.data.description && (
            <p class="muted desc">{post.data.description}</p>
          )}
          <time class="date muted" datetime={post.data.date.toISOString()}>
            {fmt(post.data.date)}
          </time>
        </a>
      ))
    }
  </div>
</Base>

<style>
  h1 {
    margin: 0;
  }
  .post-grid {
    display: grid;
    /* One full-width banner per post. Deliberately not auto-fit/auto-fill:
       multi-column would shrink these back into small cards as posts land. */
    grid-template-columns: 1fr;
    gap: 1.6rem;
  }

  /* Same hard-shadow language as the skills boxes — but these are links, so
     hover presses the card into its shadow instead of doing nothing. */
  /* No min-height: the banner hugs its content. A 170px floor left ~46px of
     dead space under a short post, since the date is pushed to the foot. */
  .post-grid .post {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    border: 1px solid var(--text);
    box-shadow: 6px 6px 0 var(--text);
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .post-grid .post:hover {
    border-color: var(--text);
    transform: translate(3px, 3px);
    box-shadow: 3px 3px 0 var(--text);
  }

  .title {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.4;
    color: var(--text);
  }
  .post-grid .post:hover .title {
    color: var(--magenta);
  }

  .desc {
    margin: 0;
    font-size: 0.85rem;
  }

  /* pinned to the foot of the card so dates line up across the row */
  .date {
    margin-top: auto;
    font-size: 0.8rem;
  }
</style>

---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<Base title="Blog — Aroop Verma" description="Notes and writing.">
  <h1><span class="gradient-text">blog</span></h1>
  <hr class="rule" />

  {posts.length === 0 && <p class="muted">No posts yet.</p>}

  <ul class="list">
    {
      posts.map((post) => (
        <li class="post">
          <a class="post-link" href={`/blog/${post.id}`}>
            <time class="date muted" datetime={post.data.date.toISOString()}>
              {fmt(post.data.date)}
            </time>
            <span class="title">{post.data.title}</span>
          </a>
          {post.data.description && (
            <p class="muted desc">{post.data.description}</p>
          )}
        </li>
      ))
    }
  </ul>
</Base>

<style>
  h1 {
    margin: 0;
  }
  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.6rem;
  }
  .post-link {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 1rem;
    border: 0;
  }
  .date {
    font-size: 0.85rem;
    min-width: 7rem;
  }
  .title {
    color: var(--text);
    font-size: 1.1rem;
  }
  .post-link:hover .title {
    color: var(--magenta);
    text-shadow: var(--glow-magenta);
  }
  .desc {
    margin: 0.3rem 0 0 8rem;
    font-size: 0.9rem;
  }
  @media (max-width: 480px) {
    .desc {
      margin-left: 0;
    }
  }
</style>

---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Aroop Verma",
  description = "Aroop Verma — molecular biologist and bioinformatician working in RNA biology, computational genomics, and machine learning.",
} = Astro.props;

const nav = [
  { href: "/", label: "home" },
  { href: "/about", label: "about" },
  { href: "/projects", label: "projects" },
  { href: "/blog", label: "blog" },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link
      rel="preload"
      href="/fonts/Monocraft.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script is:inline>
      // Set theme before paint to avoid a flash. Defaults to dark; the
      // attribute is already on <html> so no-JS lands on dark too.
      (function () {
        var saved = localStorage.getItem("theme");
        document.documentElement.dataset.theme = saved === "light" ? "light" : "dark";
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="wrap nav">
        {/* Every item — home included — is an <li> in this one list. They used
            to sit in two different flex containers, which left home unable to
            share a baseline with the rest. */}
        <ul class="nav-links">
          {
            nav.map((n) => (
              <li>
                <a
                  href={n.href}
                  class:list={["nav-link", { active: isActive(n.href) }]}
                  aria-current={isActive(n.href) ? "page" : undefined}
                >
                  {n.label}
                </a>
              </li>
            ))
          }
          <li>
            <!-- Label matches the dark default; the script re-syncs it if a
                 light preference is stored. -->
            <button id="theme-toggle" class="theme-toggle" type="button">
              light mode
            </button>
          </li>
        </ul>
      </nav>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site-footer wrap">
      <span class="muted">© {year} Aroop Verma</span>
      <span class="muted">built with Astro</span>
    </footer>

    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        var root = document.documentElement;
        function sync() {
          var dark = root.dataset.theme === "dark";
          btn.textContent = dark ? "light mode" : "dark mode";
          btn.setAttribute("aria-pressed", String(dark));
          btn.setAttribute(
            "aria-label",
            dark ? "Switch to light mode" : "Switch to dark mode",
          );
        }
        sync();
        btn.addEventListener("click", function () {
          var next = root.dataset.theme === "dark" ? "light" : "dark";
          root.dataset.theme = next;
          localStorage.setItem("theme", next);
          sync();
        });
      })();
    </script>

    <style>
      body {
        display: flex;
        flex-direction: column;
      }

      main {
        flex: 1;
        width: 100%;
        padding-block: clamp(1rem, 3vw, 2rem) clamp(2rem, 6vw, 4rem);
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(8px);
        background: color-mix(in srgb, var(--bg) 82%, transparent);
        border-bottom: 1px solid var(--border);
      }

      .nav {
        padding-block: 0.9rem;
        font-size: 0.95rem;
      }

      .nav-links {
        display: flex;
        align-items: baseline;
        gap: 0.35rem 1.1rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      /* Baseline-aligned, so the toggle's text sits on the same line as the
         links regardless of their differing box heights. Deliberately no
         flex-wrap: the row must stay one line — wrapping is what produced the
         three-row bar on phones. Narrow screens tighten instead, below. */
      @media (max-width: 480px) {
        .nav {
          font-size: 0.8rem;
        }
        .nav-links {
          gap: 0.8rem;
        }
      }

      /* The auto margin must sit on the flex item (the <li>), not the button
         inside it. Auto rather than a fixed offset — a fixed one overflowed
         on mobile. */
      .nav-links li:last-child {
        margin-left: auto;
      }

      /* text dark-mode toggle, pinned to the far right (responsive, no overflow) */
      .theme-toggle {
        padding: 0;
        background: none;
        border: 0;
        font: inherit;
        letter-spacing: inherit;
        color: var(--muted);
        cursor: pointer;
        white-space: nowrap;
      }
      .theme-toggle:hover {
        color: var(--cyan);
        text-shadow: var(--glow-cyan);
      }
      .theme-toggle:focus-visible {
        outline: 2px solid var(--magenta);
        outline-offset: 2px;
      }

      .nav-link {
        color: var(--muted);
        border: 0;
      }
      .nav-link:hover {
        color: var(--cyan);
        text-shadow: var(--glow-cyan);
      }
      /* The current tab is signalled by colour, not a rule. Same specificity as
         :hover and declared after it, so the active tab keeps its colour on
         hover rather than flipping to the cyan hover state. `aria-current` is
         what carries this to assistive tech — colour is not the only signal. */
      .nav-link.active {
        color: var(--magenta);
        text-shadow: var(--glow-magenta);
      }

      .site-footer {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 0.5rem;
        padding-block: 2rem;
        border-top: 1px solid var(--border);
        font-size: 0.82rem;
      }
    </style>
  </body>
</html>
